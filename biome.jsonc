{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/vitest"],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "!**/dist",
      "!**/target",
      "!**/node_modules",
      "!**/.turbo",
      "!**/.agents",
      "!**/.claude",
      "!**/*.d.ts",
      "!**/*.d.mts",
      "!**/*.d.cts",
      "!crates/uncontainerizable-node/npm",
      "!pnpm-lock.yaml"
    ]
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedImports": "off"
      },
      "style": {
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "type"
          }
        },
        "noNestedTernary": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noReExportAll": "off"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "identifierOrder": "lexicographic",
            "groups": [
              ":URL:",
              ":BLANK_LINE:",
              ":NODE:",
              ":BUN:",
              ":PACKAGE_WITH_PROTOCOL:",
              ":BLANK_LINE:",
              "react",
              ":BLANK_LINE:",
              ["next", "next/**"],
              ":BLANK_LINE:",
              [":PACKAGE:", "!@apps/**", "!@repo/**"],
              ":BLANK_LINE:",
              "@repo/**",
              ":BLANK_LINE:",
              "@apps/**",
              ":BLANK_LINE:",
              ":ALIAS:" /* Workspace matcher takes precedence over :ALIAS: */,
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        }
      }
    }
  }
}
