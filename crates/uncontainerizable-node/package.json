{
  "name": "@uncontainerizable/native",
  "version": "0.1.3",
  "description": "Native bindings for uncontainerizable",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inakineitor/uncontainerizable.git",
    "directory": "crates/uncontainerizable-node"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "artifacts": "napi create-npm-dirs && napi artifacts --npm-dir npm",
    "build": "napi build --platform --release --esm --output-dir dist",
    "build:native": "napi build --platform --release --esm --output-dir dist",
    "build:debug": "napi build --platform --esm --output-dir dist",
    "prepublishOnly": "napi prepublish -t npm && publint",
    "lint:package": "publint",
    "version": "napi version",
    "clean": "rm -rf .turbo target dist npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5",
    "publint": "^0.3"
  },
  "napi": {
    "binaryName": "uncontainerizable",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
